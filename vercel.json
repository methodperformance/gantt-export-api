{
  "version": 2,
  "builds": [
    { "src": "export.py", "use": "@vercel/python" },
    { "src": "gdrive.py", "use": "@vercel/python" }
  ],
  "routes": [
    { "src": "/api/export", "dest": "/export.py" },
    { "src": "/api/gdrive", "dest": "/gdrive.py" },
    { "src": "/", "dest": "/export.py" }
  ]
}
